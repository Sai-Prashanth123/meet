# Tauri Code Signing Configuration

TAURI_SIGNING_PRIVATE_KEY=

TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# Notes:
# - The key should be a single line of base64-encoded text
# - The password is used by Tauri during the signing process
# - Both values are loaded as environment variables during build
# - For CI/CD, set these as repository secrets instead of using .env

# ─── Cloud Backend URLs ────────────────────────────────────────────────────────
# These are baked into the app JS bundle at build time (NEXT_PUBLIC_ prefix).
# For development: leave as localhost defaults (no .env needed).
# For production build: set these to your deployed server domain.

NEXT_PUBLIC_AUTH_URL=https://api.meetily.ai
NEXT_PUBLIC_API_URL=https://api.meetily.ai

# GATEWAY_URL is read by Rust at runtime.
# Set this in the OS environment when building for production, OR
# override at runtime by setting GATEWAY_URL in the system environment.
# Default in code: wss://api.meetily.ai/stream
# GATEWAY_URL=wss://api.meetily.ai/stream
